@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">

    <h1 class="mb-4 text-center">Privacy Policy</h1>

    <p class="text-muted text-center mb-5">
        Last updated: @DateTime.Now.ToShortDateString()
    </p>

    <div class="card p-4 shadow-sm">

        <h4>1. Information We Collect</h4>
        <p>
            LiftingApp collects basic workout information that you choose to enter,
            such as exercise names, muscle groups, and descriptions. We do not collect
            personal identification information such as your name, email, or location.
        </p>

        <h4 class="mt-4">2. How We Use Your Information</h4>
        <p>
            The information you provide is used solely to display and manage your
            workouts within the application. This allows you to track and organize
            your fitness routines effectively.
        </p>

        <h4 class="mt-4">3. Data Storage</h4>
        <p>
            All workout data is stored locally in a development database (LocalDB).
            This means your data is not shared with external servers or third parties.
        </p>

        <h4 class="mt-4">4. Data Sharing</h4>
        <p>
            We do not sell, trade, or share your data with any third parties. Your
            information remains private and is only accessible within this application.
        </p>

        <h4 class="mt-4">5. Security</h4>
        <p>
            While this application is intended for educational purposes, reasonable
            measures are taken to ensure that your data is stored securely within
            the local environment.
        </p>

        <h4 class="mt-4">6. Changes to This Policy</h4>
        <p>
            This privacy policy may be updated as the application evolves. Any changes
            will be reflected on this page.
        </p>

        <h4 class="mt-4">7. Contact</h4>
        <p>
            If you have any questions about this Privacy Policy, please contact the
            developer of LiftingApp.
        </p>

    </div>

</div>