@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

    <h1 class="text-center mb-4">About LiftingApp</h1>

    <div class="card p-4 shadow-sm">

        <p>
            LiftingApp is a web application designed to help users track and manage
            their workouts efficiently. Users can add, edit, and delete workouts
            while organizing them by muscle group. This application was created by 
            Ethan Morris, Jonathan Heasley, and India Hardin.as part of a web development project
            at the University of Cincinnati. It demonstrates the use of ASP.NET Core MVC,
            Entity Framework, and SQL Server.
        </p>

        <h4 class="mt-4">Features</h4>
        <ul>
            <li>Add new workouts</li>
            <li>Edit existing workouts</li>
            <li>Delete workouts</li>
            <li>View all workouts in a clean table</li>
        </ul>

        <h4 class="mt-4">Technologies Used</h4>
        <ul>
            <li>ASP.NET Core MVC</li>
            <li>Entity Framework Core</li>
            <li>SQL Server (LocalDB)</li>
            <li>Bootstrap</li>
        </ul>

    </div>

</div>
