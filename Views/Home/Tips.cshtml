@{
    ViewData["Title"] = "Tips & Tricks";
}

<div class="container mt-5">

    <h1 class="text-center mb-5">Workout Tips</h1>

    <div class="row">

        <!-- BEGINNER -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 p-3">
                <h4>🏋️ Beginner Tips</h4>
                <ul class="mt-3">
                    <li>Start with lighter weights</li>
                    <li>Learn proper form first</li>
                    <li>Stay consistent with your routine</li>
                    <li>Don’t skip warm-ups</li>
                </ul>
            </div>
        </div>

        <!-- FORM -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 p-3">
                <h4>📏 Proper Form</h4>
                <ul class="mt-3">
                    <li>Control every movement</li>
                    <li>Avoid using momentum</li>
                    <li>Keep your core engaged</li>
                    <li>Focus on full range of motion</li>
                </ul>
            </div>
        </div>

        <!-- RECOVERY -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 p-3">
                <h4>😴 Recovery</h4>
                <ul class="mt-3">
                    <li>Get enough sleep</li>
                    <li>Stay hydrated</li>
                    <li>Take rest days</li>
                    <li>Stretch after workouts</li>
                </ul>
            </div>
        </div>

    </div>

    <!-- EXTRA SECTION -->
    <div class="card shadow-sm p-4 mt-4">
        <h4>🔥 Bonus Advice</h4>
        <p class="mt-2">
            Progress takes time. Focus on consistency, good form, and gradual improvement.
            Avoid comparing yourself to others and stay committed to your own fitness journey.
        </p>
    </div>

</div>